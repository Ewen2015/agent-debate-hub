# 真实 LLM 接入（可选；不填则降级到 Mock 模式）
# 复制为 .env.local 并填入真实值，重启 dev server
#
# 火山引擎 Coding Plan（推荐用于中文 + 联网）：
VITE_LLM_API_KEY=
VITE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
VITE_LLM_MODEL=ark-code-latest

# OpenAI
# VITE_LLM_API_KEY=sk-...
# VITE_LLM_BASE_URL=https://api.openai.com/v1
# VITE_LLM_MODEL=gpt-4o-mini

# Anthropic
# VITE_LLM_API_KEY=sk-ant-...
# VITE_LLM_BASE_URL=https://api.anthropic.com/v1
# VITE_LLM_MODEL=claude-3-5-sonnet-20241022

# 联网（可选，让 LLM 自主决定 web_search 时使用）
# VITE_TAVILY_API_KEY=tvly-...
# VITE_SERPER_API_KEY=...

# ── Langfuse 浏览器端追踪（仅 public key，可安全暴露在前端 bundle）──
# 不填则关闭追踪（LangGraph 子图仍正常运行，只是不上报 trace）。
VITE_LANGFUSE_PUBLIC_KEY=pk-lf-...
VITE_LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── 评测脚本专用（Node 端，绝不打包进浏览器）──
# 注意：无 VITE_ 前缀 → Vite 不会内联。仅在 scripts/eval/ 下使用。
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# 评测用 LLM（独立于辩论用 VITE_LLM_*，避免污染计费/上下文）
EVAL_LLM_API_KEY=
EVAL_LLM_BASE_URL=https://api.openai.com/v1
EVAL_LLM_MODEL=gpt-4o-mini

